<def tag="show-page" for="XxxMemo">
  <page merge title="#{ht 'xxx_memos.show.title', :default=>['Xxx Memo'] }">

    <body: class="show-page xxx-memo" param/>

    <content: param>
          <header param="content-header">
            <h2 param="heading">
              <ht key="xxx_memos.show.heading" name="&this.respond_to?(:name) ? this.name : ''">
                <name/>
              </ht>
            </h2>

            <record-flags fields="" param/>

            <a action="edit" if="&can_edit?" param="edit-link">
              <ht key="xxx_memos.actions.edit" name="&this.respond_to?(:name) ? this.name : ''">
                Edit Xxx Memo
              </ht>
            </a>
          </header>

          <section param="content-body">
            <field-list fields="chiave, valore" param/>
          </section>
    </content:>

  </page>
</def>


<def tag="edit-page" for="XxxMemo">
  <page merge title="#{ht 'xxx_memos.edit.title', :default=>['Edit Xxx Memo'] }">

    <body: class="edit-page xxx-memo" param/>

    <content:>
      <section param="content-header">
        <h2 param="heading">
          <ht key="xxx_memos.edit.heading" name="&this.respond_to?(:name) ? this.name : ''">
            Edit <type-name/>
          </ht>
        </h2>
        <delete-button label="#{ht 'xxx_memos.actions.delete', :default=>['Remove This Xxx Memo']}" param/>
      </section>

      <section param="content-body">
        <form param/>
      </section>
    </content:>

  </page>
</def>




