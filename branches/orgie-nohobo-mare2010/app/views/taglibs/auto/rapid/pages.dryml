  <page merge title="#{ht 'picture_appearances.index.title', :default=>['Picture Appearances'] }">
    <body: class="index-page picture-appearance" param/>

    <content: param>
      <header param="content-header">
        <h2 param="heading">
          <ht key="picture_appearances.index.heading">
            Picture Appearances
          </ht>
        </h2>

        <p param="count" if>
          <ht key="picture_appearances.collection.count" count="&this.size">
            There <count prefix="are"/>
          </ht>
        </p>
      </header>

      <section param="content-body">
        <a action="new" to="&model" param="new-link">
          <ht key="picture_appearances.actions.new">New Picture Appearance</ht>
        </a>

        <page-nav param="top-page-nav"/>

        <collection param/>

        <page-nav param="bottom-page-nav"/>


      </section>
    </content:>
  </page>
</def>


<def tag="new-page" for="PictureAppearance">
  <page merge title="#{ht 'picture_appearances.new.title', :default=>[' New Picture Appearance'] }">
    <body: class="new-page picture-appearance" param/>

    <content: param>
      <section param="content-header">
        <h2 param="heading">
          <ht key="picture_appearances.new.heading">
            New Picture Appearance
          </ht>
        </h2>
      </section>

      <section param="content-body">
        <form param>
          <submit: label="#{ht 'picture_appearances.actions.create', :default=>['Create Picture Appearance']}"/>
        </form>
      </section>
    </content:>
  </page>
</def>


<def tag="show-page" for="PictureAppearance">
  <page merge title="#{ht 'picture_appearances.show.title', :default=>['Picture Appearance'] }">

    <body: class="show-page picture-appearance" param/>

    <content: param>
          <header param="content-header">
            <h2 param="heading">
              <ht key="picture_appearances.show.heading" name="&this.respond_to?(:name) ? this.name : ''">
                <name/>
              </ht>
            </h2>

            <record-flags fields="" param/>

            <a action="edit" if="&can_edit?" param="edit-link">
              <ht key="picture_appearances.actions.edit" name="&this.respond_to?(:name) ? this.name : ''">
                Edit Picture Appearance
              </ht>
            </a>
          </header>

          <section param="content-body">
            <field-list fields="id_foto, id_gol, note, data_commento, id_utente_commento" param/>
          </section>
    </content:>

  </page>
</def>


<def tag="edit-page" for="PictureAppearance">
  <page merge title="#{ht 'picture_appearances.edit.title', :default=>['Edit Picture Appearance'] }">

    <body: class="edit-page picture-appearance" param/>

    <content:>
      <section param="content-header">
        <h2 param="heading">
          <ht key="picture_appearances.edit.heading" name="&this.respond_to?(:name) ? this.name : ''">
            Edit <type-name/>
          </ht>
        </h2>
        <delete-button label="#{ht 'picture_appearances.actions.delete', :default=>['Remove This Picture Appearance']}" param/>
      </section>

      <section param="content-body">
        <form param/>
      </section>
    </content:>

  </page>
</def>





