<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en" lang="en">
  <head>
    <meta http-equiv="content-type" content="text/html;charset=UTF-8" />
    <!-- uncomment here to enable refresh of the page... 
			<meta http-equiv="refresh" content="600" />
		-->
    <%= stylesheet_link_tag "scaffold", "Orgie", 'div', 'tabbing' %>
    <% if mymodel == "sites" then %>
      <%= "<title>Orgie :: Home</title>" %>
    <% else %>
      <% if controller.action_name == "index" then %>
        <%= "<title>Orgie :: "+ mymodel.gsub("_"," ").capitalize+"</title>" %>
      <% elsif controller.action_name == "new" then %>
        <%= "<title>Orgie :: Add "+ controller.action_name.gsub("_"," ") + " " + mymodel.gsub("_"," ").capitalize.singularize  + "</title>" %>
      <% else #edit or show %>
        <%= "<title>Orgie :: " + myobj.name   + "</title>" %>
      <% end %>
    <% end %>
    <%= javascript_include_tag :defaults %>
    <%#= include_tiny_mce_if_needed %>
  </head>

  <body>
    <script type="text/javascript" src="/javascripts/wz_tooltip/wz_tooltip.js"></script>
    <div id="whole_page" class="whole_page_<%= failover_host? ? "failover" : ENV["RAILS_ENV"] %>" >
      <%= render :file => "shared/header" %>
      <div id="page_content">
        <% if flash[:notice] %>
          <p id="flash-notice"><%= flash[:notice] %></p>
        <% end %>
        <%# if user_session.can_read?(controller.controller_name) %>
          <%= yield  %>
        <%# else %>
          <%#= render :file => "shared/unauthorized" %>
        <%# end %>
      </div>
      <%= render :file => "shared/footer" %>
    </div>
  </body>
</html>
