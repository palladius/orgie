<h1>Listing cities</h1>

<table>
  <tr>
    <th>Nomecitta</th>
    <th>Sigla</th>
    <th>Regione</th>
    <th>Id pseudoid</th>
  </tr>

<% @cities.each do |city| %>
  <tr>
    <td><%=h city.nomecitta %></td>
    <td><%=h city.sigla %></td>
    <td><%=h city.regione %></td>
    <td><%=h city.id_pseudoid %></td>
    <td><%= link_to 'Show', city %></td>
    <td><%= link_to 'Edit', edit_city_path(city) %></td>
    <td><%= link_to 'Destroy', city, :confirm => 'Are you sure?', :method => :delete %></td>
  </tr>
<% end %>
</table>

<br />

<%= link_to 'New city', new_city_path %>